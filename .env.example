OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# TLS: default uses certifi. If you still see CERTIFICATE_VERIFY_FAILED:
# - Point to a PEM with your corporate root CA:
#   SSL_CERT_FILE=C:\path\to\corp-ca-bundle.pem
# - Dev only (insecure): OPENROUTER_SSL_VERIFY=false
# OPENROUTER_SSL_VERIFY=true
